# ============================================================================
# FAKE NEWS DETECTION PROJECT - .gitignore
# ============================================================================
# Created: Nov 14, 2025
# Purpose: Protect sensitive data, large files, and maintain clean repo
# ============================================================================

# ============================================================================
# 🔒 SENSITIVE DATA - NEVER COMMIT THESE!
# ============================================================================
# API Keys and credentials
kaggle.json
.kaggle/
api_keys.txt
YOUR_API_KEYS.md
*.env
.env
.env.local
*.key
*.pem

# ============================================================================
# 📊 LARGE DATASET FILES - TOO BIG FOR GIT
# ============================================================================
# Main datasets
*.csv
world_class_dataset/
kaggle_data/
enhanced_dataset/
realtime_data/
additional_data/
final_dataset/

# Compressed data
*.zip
*.tar.gz
*.rar
*.7z

# Data folders
data/
Data/
Data-set/
Data_set/
Dataset/
datasets/
politifact/
kaggle_data_additional/

# ============================================================================
# 🤖 MODEL FILES - LARGE BINARY FILES
# ============================================================================
# PyTorch models
*.pt
*.pth
roberta-large_best.pt
bert-large-uncased_best.pt

# Other ML models
*.pkl
*.h5
*.model
*.ckpt
model.pkl
enhanced_model.pt

# Model results
ensemble_results.json
training_results/

# ============================================================================
# 🐍 PYTHON SPECIFIC
# ============================================================================
# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environments
venv/
env/
ENV/
.venv/
.env/
virtualenv/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# ============================================================================
# 📓 JUPYTER NOTEBOOK
# ============================================================================
.ipynb_checkpoints/
*.ipynb

# ============================================================================
# 💻 IDE & EDITOR
# ============================================================================
# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================================================
# 📝 LOGS & TEMPORARY FILES
# ============================================================================
# Logs
*.log
*.out
training.log
nohup.out

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Databases
*.sqlite3
*.db

# ============================================================================
# 🖼️ VISUALIZATIONS & OUTPUTS (Optional - Comment out if needed)
# ============================================================================
# Uncomment these if you don't want to track visualizations
# visualizations/
# *.png
# *.jpg
# *.jpeg

# ============================================================================
# 🖥️ SYSTEM FILES
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# ============================================================================
# 🧪 TESTING & COVERAGE
# ============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
*.cover

# ============================================================================
# 📦 NODE MODULES (Frontend)
# ============================================================================
node_modules/
npm-debug.log
yarn-error.log
frontend/node_modules/
frontend/dist/
frontend/build/

# ============================================================================
# ✅ WHAT TO COMMIT (NOT IGNORED)
# ============================================================================
# ✅ Source code: *.py
# ✅ Frontend: frontend/src/
# ✅ Documentation: *.md
# ✅ Config: requirements*.txt
# ✅ Templates: templates/
# ✅ Small visualizations: visualizations/*.png (if needed)
# ✅ Scripts: *.bat, *.sh
# ============================================================================
